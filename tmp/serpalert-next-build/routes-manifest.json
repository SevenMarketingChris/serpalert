    },
    {
      "page": "/api/cron/serp-check",
      "regex": "^/api/cron/serp\\-check(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/cron/serp\\-check(?:/)?$"
    },
    {
      "page": "/api/health",
      "regex": "^/api/health(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/health(?:/)?$"
    },
    {
      "page": "/api/test-screenshot",
      "regex": "^/api/test\\-screenshot(?:/)?$",
