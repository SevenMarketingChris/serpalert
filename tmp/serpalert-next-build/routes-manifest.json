    },
    {
      "page": "/client/[token]",
      "regex": "^/client/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/client/(?<nxtPtoken>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/[brandId]",
      "regex": "^/dashboard/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPbrandId": "nxtPbrandId"
      },
      "namedRegex": "^/dashboard/(?<nxtPbrandId>[^/]+?)(?:/)?$"
    },
    {
