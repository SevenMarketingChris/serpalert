{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.public.blob.vercel-storage.com https://api.dataforseo.com; connect-src 'self' https://serpapi.com https://api.dataforseo.com; font-src 'self' data:; frame-ancestors 'none'"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/brands/[brandId]/ads/[adId]/status",
      "regex": "^/api/brands/([^/]+?)/ads/([^/]+?)/status(?:/)?$",
      "routeKeys": {
        "nxtPbrandId": "nxtPbrandId",
        "nxtPadId": "nxtPadId"
      },
      "namedRegex": "^/api/brands/(?<nxtPbrandId>[^/]+?)/ads/(?<nxtPadId>[^/]+?)/status(?:/)?$"
    },
    {
      "page": "/api/brands/[brandId]/check",
      "regex": "^/api/brands/([^/]+?)/check(?:/)?$",
      "routeKeys": {
        "nxtPbrandId": "nxtPbrandId"
      },
      "namedRegex": "^/api/brands/(?<nxtPbrandId>[^/]+?)/check(?:/)?$"
    },
    {
      "page": "/api/brands/[brandId]/checks/[checkId]/status",
      "regex": "^/api/brands/([^/]+?)/checks/([^/]+?)/status(?:/)?$",
      "routeKeys": {
        "nxtPbrandId": "nxtPbrandId",
        "nxtPcheckId": "nxtPcheckId"
      },
      "namedRegex": "^/api/brands/(?<nxtPbrandId>[^/]+?)/checks/(?<nxtPcheckId>[^/]+?)/status(?:/)?$"
    },
    {
      "page": "/api/digest/[brandId]",
      "regex": "^/api/digest/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPbrandId": "nxtPbrandId"
      },
      "namedRegex": "^/api/digest/(?<nxtPbrandId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/evidence/[checkId]/cease-desist",
      "regex": "^/api/evidence/([^/]+?)/cease\\-desist(?:/)?$",
      "routeKeys": {
        "nxtPcheckId": "nxtPcheckId"
      },
      "namedRegex": "^/api/evidence/(?<nxtPcheckId>[^/]+?)/cease\\-desist(?:/)?$"
    },
    {
      "page": "/api/evidence/[checkId]/pdf",
      "regex": "^/api/evidence/([^/]+?)/pdf(?:/)?$",
      "routeKeys": {
        "nxtPcheckId": "nxtPcheckId"
      },
