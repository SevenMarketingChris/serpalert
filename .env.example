# Database (Neon via Vercel Marketplace)
DATABASE_URL=your-neon-database-url-here

# DataForSEO (screenshots)
DATAFORSEO_LOGIN=your-dataforseo-login
DATAFORSEO_PASSWORD=your-dataforseo-password

# SerpAPI (ad detection)
SERPAPI_KEY=your-serpapi-key

# Vercel Blob (screenshot storage)
BLOB_READ_WRITE_TOKEN=your-blob-token

# Auth secrets
ADMIN_SECRET=your-admin-secret
CRON_SECRET=your-cron-secret

# Clerk (via Vercel Marketplace - auto-provisioned)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PRICE_ID=your-stripe-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App URL
NEXT_PUBLIC_APP_URL=https://serpalert.co.uk

# Optional
SLACK_WEBHOOK_URL=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_REFRESH_TOKEN=your-google-ads-refresh-token

# Email (Resend)
RESEND_API_KEY=re_your-resend-api-key

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Optional
AHREFS_API_TOKEN=
